<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= query %> - Aetherium Search</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: #0d1117;
      color: #c9d1d9;
      line-height: 1.6;
      min-height: 100vh;
    }

    ul {
      white-space-collapse: collapse;
    }

    .header {
      background: #161b22;
      border-bottom: 1px solid #30363d;
      padding: 16px 24px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .logo {
      font-size: 18px;
      font-weight: 700;
      color: #58a6ff;
      text-decoration: none;
      white-space: nowrap;
    }

    .search-form {
      flex: 1;
      max-width: 640px;
    }

    .search-input {
      width: 100%;
      padding: 10px 16px;
      border: 1px solid #30363d;
      border-radius: 8px;
      background: #0d1117;
      color: #c9d1d9;
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: #58a6ff;
      box-shadow: 0 0 0 3px rgba(56, 139, 253, 0.15);
    }

    .search-input::placeholder {
      color: #484f58;
    }

    .content {
      max-width: 960px;
      margin: 0 auto;
      padding: 24px;
    }

    .ai-overview {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 32px;
    }

    .ai-overview-label {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #58a6ff;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .ai-overview-label::before {
      content: "✦";
      font-size: 14px;
    }

    .ai-overview.error {
      border-color: #f8514944;
    }

    .ai-overview.error .ai-overview-label {
      color: #f85149;
    }

    .ai-overview.error .ai-overview-label::before {
      content: "⚠";
    }

    .ai-overview p {
      font-size: 15px;
      line-height: 1.7;
      white-space: pre-wrap;
    }

    .results-count {
      font-size: 13px;
      color: #484f58;
      margin-bottom: 20px;
    }

    .result {
      padding: 20px 0;
      border-bottom: 1px solid #21262d;
    }

    .result:last-child {
      border-bottom: none;
    }

    .result-url {
      font-size: 12px;
      color: #8b949e;
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .result-url img {
      width: 16px;
      height: 16px;
      border-radius: 2px;
    }

    .result-title {
      font-size: 18px;
      margin-bottom: 6px;
    }

    .result-title a {
      color: #58a6ff;
      text-decoration: none;
    }

    .result-title a:hover {
      text-decoration: underline;
    }

    .result-snippet {
      font-size: 14px;
      color: #8b949e;
      line-height: 1.6;
    }

    .result-engine {
      font-size: 11px;
      color: #484f58;
      background: #21262d;
      padding: 2px 8px;
      border-radius: 12px;
      display: inline-block;
      margin-top: 8px;
    }

    .empty-state {
      text-align: center;
      padding: 60px 24px;
      color: #484f58;
    }

    .empty-state h2 {
      font-size: 20px;
      margin-bottom: 8px;
      color: #8b949e;
    }

    @media (max-width: 640px) {
      .header-inner { flex-wrap: wrap; }
      .search-form { order: 2; max-width: 100%; }
      .content { padding: 16px; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">Aetherium Search</a>
      <form class="search-form" action="/search" method="GET">
        <input
          type="search"
          class="search-input"
          name="q"
          placeholder="Search the web..."
          value="<%= query %>"
          autofocus
        />
      </form>
    </div>
  </header>

  <main class="content">
    <% if (aiOverview) { %>
    <section class="ai-overview">
      <div class="ai-overview-label">AI Overview</div>
      <p><%= aiOverview %></p>
    </section>
    <% } else if (aiOverviewError) { %>
    <section class="ai-overview error">
      <div class="ai-overview-label">AI Overview unavailable</div>
      <p><%= aiOverviewError %></p>
    </section>
    <% } %>

    <div class="results-count">
      <%= results.length %> result<%= results.length !== 1 ? 's' : '' %> for "<%= query %>"
    </div>

    <% if (results.length === 0 && !aiOverviewError) { %>
    <div class="empty-state">
      <h2>No results found</h2>
      <p>Try different keywords or check your spelling.</p>
    </div>
    <% } %>

    <% results.forEach(function(result) { %>
    <article class="result">
      <div class="result-url">
        <% if (result.img_src) { %>
          <img src="<%= result.img_src %>" alt="">
        <% } %>
        <%= result.parsed_url ? result.parsed_url.join(' > ') : result.url %>
      </div>
      <h3 class="result-title">
        <a href="<%= result.url %>" target="_blank" rel="noopener noreferrer"><%= result.title %></a>
      </h3>
      <% if (result.content) { %>
      <p class="result-snippet"><%= result.content %></p>
      <% } %>
      <% if (result.engine) { %>
      <span class="result-engine"><%= result.engine %></span>
      <% } %>
    </article>
    <% }); %>
  </main>
</body>
</html>
