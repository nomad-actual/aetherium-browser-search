# Required
SEARXNG_URL=http://localhost:8080

# Optional: SearXNG authentication (if your instance requires a key)
SEARXNG_API_KEY=

# Optional: LLM API (llamacpp or OpenAI-compatible)
LLM_API_URL=http://localhost:8081
LLM_API_KEY=
LLM_MODEL=llama3.1-8b-instruct
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2
STREAM_AI_OVERVIEW=true

# Server
PORT=3000
HOST=0.0.0.0

# Custom AI overview prompt (use {{query}} and {{results}} as placeholders)
# AI_OVERVIEW_PROMPT=Based on the following search results...

# Research mode: enables web scraping for deeper analysis
RESEARCH_MODE=false

# Research prompt: used when research mode scrapes URLs and sends to the LLM
# Available placeholders: {{query}}, {{results}}, {{scrapedContent}}
# RESEARCH_PROMPT=

# Scraper configuration
SCRAPER_TIMEOUT_MS=15000
SCRAPER_CONTENT_LIMIT=8000
SCRAPER_CONCURRENCY=3
SCRAPER_REDDIT_MAX_COMMENTS=10
SCRAPER_REDDIT_MAX_DEPTH=3
SCRAPER_REDDIT_COMMENT_MAX_LEN=2000
SCRAPER_REDDIT_IGNORE_COMMENTS=false
SCRAPER_BASICHTML_MIN_READABLE=500

# Scraper - Playwright (headless browser, handles sites that block fetch)
SCRAPER_PLAYWRIGHT_ENABLED=true
SCRAPER_PLAYWRIGHT_TIMEOUT_MS=15000

# Default theme (gruvbox, tokyonight, dark-aero, paper, midnight)
DEFAULT_THEME=paper

# Debug logging
# DEBUG=true
